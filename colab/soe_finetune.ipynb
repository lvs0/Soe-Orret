   "source": [
    "# 🚀 SOE Orret — Fine-tuning Notebook\n",
    "\n",
    "**Modele:** Qwen2.5-7B-Instruct (GGUF) · **Runtime:** TPU/Colab Pro\n",
    "\n",
    "Ce notebook fine-tune le modele **Soe/Orret** sur tes donnees .loop custom.\n",
    "\n",
    "## 1. Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 1. Setup\n",
    "!nvidia-smi --query-gpu=name,memory.total --format=csv,noheader 2>/dev/null || echo \"No GPU detected\"\n",
    "\n",
    "# Installer dependances\n",
    "!pip install -q unsloth transformers peft datasets accelerate bitsandbytes\n",
    "!pip install -q scipy scikit-learn\n",
    "\n",
    "import os\n",
    "HOME = os.path.expanduser(\"~\")\n",
    "SOE_DIR = os.path.join(HOME, \"soe\")\n",
    "print(f\"📁 SOE_DIR: {SOE_DIR}\")\n",
    "\n",
    "from google.colab import drive\n",
    "drive.mount(\"/content/drive\")\n",
    "DATA_DIR = \"/content/drive/MyDrive/soe_data\"  # Tes .loop ici\n",
    "MODEL_DIR = os.path.join(DATA_DIR, \"models\")\n",
    "os.makedirs(DATA_DIR, exist_ok=True)\n",
    "os.makedirs(MODEL_DIR, exist_ok=True)\n",
    "print(f\"📂 Data: {DATA_DIR}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Charger les donnees .loop\n",
    "\n",
    "**Format .loop:** binaire colonnaire, streaming-ready. Alternatif: JSONL."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 2. Charger les donnees\n",
    "import json, glob\n",
    "\n",
    "def load_loop_as_jsonl(loop_path):\n",
    "    \"\"\"Lit un fichier .loop (v1) et retourne une liste de dicts.\"\"\"\n",
    "    import struct, mmap\n",
    "    \n",
    "    def unpack_hdr(data):\n",
    "        magic = data[0:4]\n",
    "        assert magic == b\"LOOP\", f\"Not a .loop file: {magic}\"\n",
    "        ver = struct.unpack(\"<H\", data[4:6])[0]\n",
    "        nb = struct.unpack(\"<Q\", data[8:16])[0]\n",
    "        return ver, nb\n",
    "    \n",
    "    f = open(loop_path, \"rb\")\n",
    "    raw = f.read()\n",
    "    f.close()\n",
    "    \n",
    "    ver, nb = unpack_hdr(raw[:22])\n",
    "    offsets = [struct.unpack(\"<Q\", raw[22+i*8 : 22+(i+1)*8])[0] for i in range(nb)]\n",
    "    \n",
    "    items = []\n",
    "    for off in offsets:\n",
    "        blen = struct.unpack(\"<Q\", raw[off:off+8])[0]\n",
    "        bd = raw[off+8:off+8+blen]\n",
    "        pos = 0\n",
    "        nr = struct.unpack(\"<I\", bd[pos:pos+4])[0]; pos += 4\n",
    "        _nc = struct.unpack(\"<I\", bd[pos:pos+4])[0]; pos += 4\n",
    "        cols = {}\n",
    "        for _ in range(_nc):\n",
    "            klen = struct.unpack(\"<I\", bd[pos:pos+4])[0]; pos += 4\n",
    "            key = bd[pos:pos+klen].decode(); pos += klen\n",
    "            dlen = struct.unpack(\"<Q\", bd[pos:pos+8])[0]; pos += 8\n",
    "            cols[key] = bd[pos:pos+dlen]; pos += dlen\n",
    "        \n",
    "        for i in range(nr):\n",
    "            row = {}\n",
    "            for key, cb in cols.items():\n",
    "                if key in [\"prompt\",\"response\",\"category\",\"source\"]:\n",
    "                    import json\n",
    "                    row[key] = json.loads(cb.decode())[i]\n",
    "            if \"prompt\" in row and \"response\" in row:\n",
    "                items.append(row)\n",
    "    \n",
    "    return items\n",
    "\n",
    "# Charger tous les .loop du repertoire\n",
    "all_items = []\n",
    "for loop_file in glob.glob(os.path.join(DATA_DIR, \"*.loop\")):\n",
    "    try:\n",
    "        items = load_loop_as_jsonl(loop_file)\n",
    "        all_items.extend(items)\n",
    "        print(f\"  ✅ {os.path.basename(loop_file)}: {len(items)} items\")\n",
    "    except Exception as e:\n",
    "        print(f\"  ❌ {os.path.basename(loop_file)}: {e}\")\n",
    "\n",
    "# Fallback: creer quelques donnees de demo si vide\n",
    "if not all_items:\n",
    "    print(\"⚠️  Aucun .loop trouve — creation de donnees demo\")\n",
    "    all_items = [\n",
    "        {\"prompt\": f\"Question {i}: Explain concept X.\", \"response\": f\"Answer {i}: Concept X is fundamental in AI.\"}\n",
    "        for i in range(100)\n",
    "    ]\n",
    "\n",
    "print(f\"\\n📊 Total items: {len(all_items)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Preparer pour fine-tuning (QLORA)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 3. Preparer le dataset\n",
    "from datasets import Dataset\n",
    "\n",
    "# Formater en instruction-style\n",
    "def format_instruction(item):\n",
    "    return {\n",
    "        \"text\": f\"### Instruction:\\n{item['prompt']}\\n\\n### Response:\\n{item['response']}\\n\"\n",
    "    }\n",
    "\n",
    "formatted = [format_instruction(item) for item in all_items if \"prompt\" in item and \"response\" in item]\n",
    "\n",
    "train_data = Dataset.from_list(formatted)\n",
    "print(f\"Dataset: {len(train_data)} examples\")\n",
    "print(train_data[0][\"text\"][:200])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title Tokeniser\n",
    "from transformers import AutoTokenizer\n",
    "\n",
    "MODEL_NAME = \"Qwen/Qwen2.5-7B-Instruct\"  # ou chemin local GGUF\n",
    "\n",
    "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME, trust_remote_code=True)\n",
    "tokenizer.pad_token = tokenizer.eos_token\n",
    "\n",
    "def tokenize(example):\n",
    "    result = tokenizer(\n",
    "        example[\"text\"],\n",
    "        truncation=True,\n",
    "        max_length=512,\n",
    "        padding=\"max_length\"\n",
    "    )\",
    "    result[\"labels\"] = result[\"input_ids\"].copy()\n",
    "    return result\n",
    "\n",
    "train_data = train_data.map(tokenize, batched=True, remove_columns=[\"text\"])\n",
    "print(train_data)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Unsloth / QLoRA Fine-tuning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 4. Unsloth QLoRA Fine-tuning\n",
    "# Unsloth = 2x plus rapide, 50% moins de RAM\n",
    "\n",
    "from unsloth import UnslothTrainer, UnslothTrainingArguments\n",
    "from unsloth import is_bf16_supported\n",
    "from trl import SFTTrainer\n",
    "\n",
    "model, tokenizer = UnslothTrainer.from_pretrained(\n",
    "    MODEL_NAME,\n",
    "    load_in_4bit=True,\n",
    "    fast_inference=True,\n",
    ")\n",
    "\n",
    "trainer = SFTTrainer(\n",
    "    model=model,\n",
    "    tokenizer=tokenizer,\n",
    "    train_dataset=train_data,\n",
    "    dataset_text_field=\"text\",\n",
    "    max_seq_length=512,\n",
    "    dataset_num_proc=2,\n",
    "    packing=True,\n",
    "    args=UnslothTrainingArguments(\n",
    "        output_dir=\"./soe_orret_model\",\n",
    "        per_device_train_batch_size=2,\n",
    "        gradient_accumulation_steps=4,\n",
    "        warmup_steps=10,\n",
    "        num_train_epochs=1,\n",
    "        learning_rate=2e-4,\n",
    "        embedding_learning_rate=1e-5,\n",
    "        fp16=not is_bf16_supported(),\n",
    "        bf16=is_bf16_supported(),\n",
    "        logging_steps=10,\n",
    "        save_steps=100,\n",
    "        save_total_limit=2,\n",
    "    ),\n",
    ")\n",
    "\n",
    "# Lancer\n",
    "print(\"🚀 Starting fine-tuning...\")\n",
    "trainer.train()\n",
    "print(\"✅ Fine-tuning termine!\")\n",
    "\n",
    "# Sauvegarder\n",
    "trainer.save_model(os.path.join(MODEL_DIR, \"soe_orret_v1\"))\n",
    "tokenizer.save_pretrained(os.path.join(MODEL_DIR, \"soe_orret_v1\"))\n",
    "print(f\"💾 Modele sauvegarde dans {MODEL_DIR}/soe_orret_v1\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
